{
  "name": "reflect-ai-be",
  "version": "1.0.0",
  "description": "Project Mirror API and realtime voice worker",
  "type": "module",
  "main": "dist/api/apps/api/index.js",
  "scripts": {
    "dev": "npm run dev:api",
    "dev:api": "tsx watch src/apps/api/index.ts",
    "build": "npm run build:api",
    "build:api": "tsc -p tsconfig.api.json",
    "start": "npm run start:api",
    "start:api": "node dist/api/apps/api/index.js",
    "dev:agent": "tsx src/apps/agent/index.ts dev",
    "build:agent": "tsc -p tsconfig.agent.json",
    "start:agent": "node dist/agent/apps/agent/index.js start",
    "agent:dev": "npm run dev:agent",
    "agent:start": "npm run start:agent",
    "agent:connect": "tsx src/apps/agent/index.ts connect",
    "postinstall": "patch-package"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@clerk/express": "^2.0.8",
    "@huggingface/inference": "^4.13.15",
    "@livekit/agents": "^1.2.2",
    "@livekit/agents-plugin-openai": "^1.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "livekit-server-sdk": "^2.15.0",
    "mongoose": "^9.3.3",
    "nodemailer": "^8.0.4",
    "nodemon": "^3.1.14",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "patch-package": "^8.0.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
